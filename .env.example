# ─── Database ─────────────────────────────────────────────────────
# Supabase project connection string. Get from Supabase Dashboard > Project Settings > Database.
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# ─── Supabase ─────────────────────────────────────────────────────
SUPABASE_URL=https://[YOUR_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...                # safe to expose to browser
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # SERVER ONLY · never ship to browser

# ─── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=reports@shoppalyzer.com

# ─── App ──────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ─── Worker ───────────────────────────────────────────────────────
# How many queries the worker pulls per polling tick
WORKER_BATCH_SIZE=1
# How often the worker polls for queued queries (ms)
WORKER_POLL_INTERVAL=5000

# ─── Firecrawl pool ──────────────────────────────────────────────
# Comma-separated list of Firecrawl API keys. Optionally prefix each with
# a name + colon for friendly logging (otherwise auto-named key-1, key-2, ...).
#
# Example with auto-names:    SCRAPEGRAPH_API_KEYS=fc-abc...,fc-def...,fc-ghi...
# Example with explicit names: SCRAPEGRAPH_API_KEYS=key-1:fc-abc...,key-2:fc-def...
#
# Per-key credit usage is persisted in the Supabase `firecrawl_key_usage`
# table so it survives worker restarts.
SCRAPEGRAPH_API_KEYS=fc-...,fc-...
